     xmlns:untitled-ontology-141="http://www.semanticweb.org/pihouser/ontologies/2019/8/untitled-ontology-141#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/pihouser/ontologies/2019/8/Conditions">
        <rdfs:comment>1.0.1 - 1/03/2026: PH: Resistances / Immunities
1.0.0 - 11/09/2019, PH: Import excel sheet with conditions/damages</rdfs:comment>
        <rdfs:isDefinedBy xml:lang="f* (xsd:string)">Individual: @E* (rdfs:Label)
  Types: Conditions
  Facts:
     hasRoll @B* (xsd:float), 
     hasHit @C* (xsd:string),
     hasAdvantage @D* (xsd:string),
     hasImpact </rdfs:isDefinedBy>
        <owl:versionInfo>1.0.0 - Import excel sheet with celife json</owl:versionInfo>
    </owl:Ontology>
    


