<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/pihouser/ontologies/2019/8/untitled-ontology-141#"
     xml:base="http://www.semanticweb.org/pihouser/ontologies/2019/8/untitled-ontology-141"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
